<?xml version="1.0" encoding="utf-8"?>

<project>

	<meta
		title="My Flixel Game"
		package="com.example.myflixelgame"
		version="1.0.0"
		company="MyCompany"
	/>

	<app main="Main" file="MyFlixelGame" path="export" />

	<window
		width="1280"
		height="720"
		fps="60"
		background="#000000"
		hardware="true"
		vsync="true"
	/>

	<source path="source" />
	<haxelib name="flixel" />
	<haxelib name="flixel-ui" />
	<haxelib name="flixel-addons" />

</project>
